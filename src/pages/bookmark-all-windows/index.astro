---
import Layout from '../../layouts/Layout.astro';
import { SITE } from '../../site.config';

const baw = SITE.projects[0];
---

<Layout
  title="Bookmark All Windows - Save All Tabs with One Click"
  description="A browser extension that saves all tabs from all open windows into organized bookmark folders with a single click."
  theme="baw"
>
  <div class="max-w-[1100px] mx-auto px-6 relative z-10">
    <nav class="py-6 flex justify-between items-center">
      <a
        href="/"
        class="flex items-center gap-3 text-slate-100 no-underline hover:opacity-80 transition-opacity"
      >
        <span class="text-[1.8rem]">📚</span>
        <span class="text-xl font-semibold">Bookmark All Windows</span>
      </a>
      <ul class="hidden md:flex gap-6 list-none">
        <li>
          <a href="#features" class="text-slate-400 text-sm hover:text-slate-100 transition-colors"
            >Features</a
          >
        </li>
        <li>
          <a
            href="#how-it-works"
            class="text-slate-400 text-sm hover:text-slate-100 transition-colors">How It Works</a
          >
        </li>
        <li>
          <a
            href={baw.repoUrl}
            target="_blank"
            rel="noopener"
            class="text-slate-400 text-sm hover:text-slate-100 transition-colors">GitHub</a
          >
        </li>
      </ul>
    </nav>

    <section class="pt-20 pb-16 text-center">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 bg-[#26262e] border border-[#2e2e3a] rounded-full text-[0.85rem] text-slate-400 mb-6"
      >
        🎉 Now available for Chrome, Brave, Edge & more
      </div>
      <h1 class="text-[clamp(2.2rem,5vw,3.5rem)] font-bold leading-tight mb-5">
        Save <span class="gradient-text">all your tabs</span><br />with one click
      </h1>
      <p class="text-lg text-slate-400 max-w-[600px] mx-auto mb-10 leading-relaxed">
        Stop losing your browsing sessions. Bookmark all tabs from all open windows into organized
        folders instantly.
      </p>
      <div class="flex gap-4 justify-center flex-wrap mb-16">
        <a
          href="https://chrome.google.com/webstore"
          target="_blank"
          rel="noopener"
          class="gradient-bg inline-flex items-center gap-2 px-7 py-3.5 rounded-xl text-base font-medium text-white shadow-[0_4px_20px_rgba(249,115,22,0.3)] hover:-translate-y-0.5 hover:shadow-[0_8px_30px_rgba(249,115,22,0.4)] transition-all"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 0C8.21 0 4.831 1.757 2.632 4.501l3.953 6.848A5.454 5.454 0 0 1 12 6.545h10.691A12 12 0 0 0 12 0zM1.931 5.47A11.943 11.943 0 0 0 0 12c0 6.012 4.42 10.991 10.189 11.864l3.953-6.847a5.45 5.45 0 0 1-6.865-2.29zm13.342 2.166a5.446 5.446 0 0 1 1.45 7.09l.002.001h-.002l-3.952 6.848a12.014 12.014 0 0 0 9.229-9.006zM12 16.364a4.364 4.364 0 1 1 0-8.728 4.364 4.364 0 0 1 0 8.728z"
            ></path>
          </svg>
          Add to Chrome
        </a>
        <a
          href={baw.repoUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl text-base font-medium bg-[#26262e] border border-[#2e2e3a] text-slate-100 hover:bg-[#202027] hover:border-[var(--color-accent)] transition-all"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
          View Source
        </a>
      </div>
      <div
        class="max-w-[500px] mx-auto rounded-2xl overflow-hidden border border-[#2e2e3a] hero-image-glow"
      >
        <img
          src="https://github.com/user-attachments/assets/9e19fb1d-8114-47b7-9557-493b5a685f58"
          alt="Bookmark All Windows Extension Screenshot"
          class="w-full block"
          loading="lazy"
        />
      </div>
    </section>

    <section class="py-16 border-t border-[#2e2e3a]" id="features">
      <div class="text-center mb-12">
        <h2 class="text-[2rem] font-bold mb-3">Features</h2>
        <p class="text-slate-400">Everything you need to manage your browsing sessions</p>
      </div>
      <div class="grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-5">
        {
          [
            {
              icon: '📁',
              title: 'Organized Folders',
              desc: 'Each window gets its own folder with all tabs neatly organized inside.',
            },
            {
              icon: '⏱️',
              title: 'Timestamped',
              desc: 'Automatic timestamps make it easy to find and identify your saved sessions.',
            },
            {
              icon: '🏷️',
              title: 'Custom Prefix',
              desc: 'Name your sessions with custom folder prefixes for better organization.',
            },
            {
              icon: '📊',
              title: 'Live Stats',
              desc: "See window and tab counts before saving so you know exactly what you're bookmarking.",
            },
            {
              icon: '🚫',
              title: 'Smart Filtering',
              desc: 'Automatically skips internal browser pages like chrome:// and brave://.',
            },
            {
              icon: '⚡',
              title: 'Lightning Fast',
              desc: 'Saves hundreds of tabs in seconds. No waiting, no lag.',
            },
          ].map(({ icon, title, desc }) => (
            <div class="bg-[#202027] border border-[#2e2e3a] rounded-2xl p-6 hover:border-[var(--color-accent)] hover:-translate-y-0.5 transition-all">
              <div class="text-[2rem] mb-3">{icon}</div>
              <h3 class="text-lg font-semibold mb-2">{title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed">{desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="py-16 border-t border-[#2e2e3a]" id="how-it-works">
      <div class="text-center mb-12">
        <h2 class="text-[2rem] font-bold mb-3">How It Works</h2>
        <p class="text-slate-400">Three simple steps to save your entire browsing session</p>
      </div>
      <div class="flex justify-center gap-6 flex-wrap">
        {
          [
            {
              icon: '🪟',
              title: 'Multiple Windows',
              desc: 'Open as many windows and tabs as you need',
              highlight: false,
            },
            { icon: '📚', title: 'One Click', desc: 'Click the extension button', highlight: true },
            {
              icon: '📁',
              title: 'Organized',
              desc: 'All tabs saved into folders',
              highlight: false,
            },
            { icon: '✅', title: 'Done!', desc: 'Session saved forever', highlight: false },
          ].map(({ icon, title, desc, highlight }, i, arr) => (
            <>
              <div class="text-center max-w-[180px]">
                <div
                  class={`w-20 h-20 bg-[#26262e] border-2 rounded-2xl flex items-center justify-center text-[2rem] mx-auto mb-3 ${highlight ? 'step-highlight' : 'border-[#2e2e3a]'}`}
                >
                  {icon}
                </div>
                <h3 class="text-sm font-semibold mb-1">{title}</h3>
                <p class="text-slate-400 text-xs">{desc}</p>
              </div>
              {i < arr.length - 1 && (
                <div class="hidden md:flex items-center text-[var(--color-accent)] text-2xl pt-5">
                  →
                </div>
              )}
            </>
          ))
        }
      </div>
    </section>

    <section class="py-12 text-center border-t border-[#2e2e3a]">
      <h2 class="text-[2rem] font-bold mb-3">Works Everywhere</h2>
      <p class="text-slate-400 mb-8">Compatible with all Chromium-based browsers</p>
      <div class="flex justify-center gap-8 flex-wrap">
        {
          [
            ['🦁', 'Brave'],
            ['🌐', 'Chrome'],
            ['📘', 'Edge'],
            ['🎭', 'Opera'],
            ['🔴', 'Vivaldi'],
          ].map(([icon, name]) => (
            <div class="flex flex-col items-center gap-2 text-slate-400 text-sm">
              <span class="text-[2.5rem]">{icon}</span>
              <span>{name}</span>
            </div>
          ))
        }
      </div>
    </section>

    <section class="py-12 border-t border-[#2e2e3a]" id="legal">
      <h2 class="text-[2rem] font-bold mb-8 text-center">Legal</h2>
      <div class="grid grid-cols-[repeat(auto-fit,minmax(240px,1fr))] gap-5">
        <div class="bg-[#202027] border border-[#2e2e3a] rounded-xl p-5">
          <h3 class="text-base font-semibold mb-2">📜 Terms of Use</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-3">
            By using this extension, you agree to our terms including our disclaimer of liability.
          </p>
          <a
            href="/bookmark-all-windows/terms"
            class="text-[var(--color-accent)] text-sm font-medium hover:underline">Read Terms →</a
          >
        </div>
        <div class="bg-[#202027] border border-[#2e2e3a] rounded-xl p-5">
          <h3 class="text-base font-semibold mb-2">🔒 Privacy Policy</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-3">
            We don't collect any data. Works entirely offline within your browser.
          </p>
          <a
            href="/bookmark-all-windows/privacy"
            class="text-[var(--color-accent)] text-sm font-medium hover:underline"
            >Read Privacy Policy →</a
          >
        </div>
        <div class="bg-[#202027] border border-[#2e2e3a] rounded-xl p-5">
          <h3 class="text-base font-semibold mb-2">⚖️ License</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-3">
            Open source and licensed under AGPL-3.0.
          </p>
          <a
            href={baw.licenseUrl}
            target="_blank"
            rel="noopener"
            class="text-[var(--color-accent)] text-sm font-medium hover:underline">View License →</a
          >
        </div>
      </div>
    </section>

    <footer class="py-10 border-t border-[#2e2e3a] text-center">
      <div class="flex justify-center gap-6 mb-4 flex-wrap text-sm">
        <a href="/" class="text-slate-500 hover:text-slate-100 transition-colors">Home</a>
        <a
          href={baw.repoUrl}
          target="_blank"
          rel="noopener"
          class="text-slate-500 hover:text-slate-100 transition-colors">GitHub</a
        >
        <a
          href="/bookmark-all-windows/terms"
          class="text-slate-500 hover:text-slate-100 transition-colors">Terms</a
        >
        <a
          href="/bookmark-all-windows/privacy"
          class="text-slate-500 hover:text-slate-100 transition-colors">Privacy</a
        >
      </div>
      <p class="text-slate-600 text-sm">{SITE.author.copyright}</p>
    </footer>
  </div>
</Layout>
