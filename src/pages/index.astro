---
import Layout from '../layouts/Layout.astro';
import { SITE, MEDIUM_RSS } from '../site.config';
---

<Layout title={SITE.title} description={SITE.description}>
  <div class="max-w-[1100px] mx-auto px-6 relative z-10">
    <!-- Nav -->
    <nav class="py-6 hidden md:flex justify-between items-center">
      <span class="gradient-text text-xl font-bold tracking-tight">{SITE.name}</span>
      <ul class="flex gap-8 list-none items-center">
        <li>
          <a href="#projects" class="text-slate-400 text-sm hover:text-slate-100 transition-colors"
            >Projects</a
          >
        </li>
        <li>
          <a href="#reading" class="text-slate-400 text-sm hover:text-slate-100 transition-colors"
            >Reading</a
          >
        </li>
        <li>
          <a href="#writing" class="text-slate-400 text-sm hover:text-slate-100 transition-colors"
            >Writing</a
          >
        </li>
        <li>
          <a
            href={SITE.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-400 hover:text-slate-100 transition-colors"
            title="LinkedIn"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>
        </li>
        <li>
          <a
            href={SITE.social.github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-400 hover:text-slate-100 transition-colors"
            title="GitHub"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
          </a>
        </li>
      </ul>
    </nav>

    <!-- Hero -->
    <section class="pt-8 md:pt-20 pb-16">
      <div class="flex flex-col md:flex-row md:items-center gap-10 max-w-[780px]">
        <img
          src={SITE.avatarUrl}
          alt={SITE.author.name}
          width="120"
          height="120"
          class="rounded-2xl border-2 border-[#2e2e3a] shrink-0 w-[96px] h-[96px] md:w-[120px] md:h-[120px] object-cover"
        />
        <div>
          <h1 class="text-[clamp(2.2rem,5vw,3.4rem)] font-bold leading-[1.1] mb-4">
            <span class="gradient-text">{SITE.author.name}</span>
          </h1>
          <p class="text-lg text-slate-400 leading-relaxed mb-6">
            Senior Software Engineer with +7 years of experience, specializing in Back-End technologies. Expertise in Java, Python, C#, Cloud Technologies alongside hands-on experience in React and Unity. Focused on delivering quality and the best products for people. Motivated by seeing users.
          </p>
          <div class="flex gap-3 flex-wrap">
            <a
              href={SITE.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-medium bg-[#26262e] border border-[#2e2e3a] text-slate-100 hover:bg-[#202027] hover:border-[var(--color-accent)] transition-all"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"
                ><path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path></svg
              >
              LinkedIn
            </a>
            <a
              href={SITE.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-medium bg-[#26262e] border border-[#2e2e3a] text-slate-100 hover:bg-[#202027] hover:border-[var(--color-accent)] transition-all"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"
                ><path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path></svg
              >
              GitHub
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Side Projects -->
    <section class="py-14 border-t border-[#2e2e3a]" id="projects">
      <div class="mb-8">
        <p class="font-mono text-xs text-[var(--color-accent)] uppercase tracking-widest mb-1">
          Open Source
        </p>
        <h2 class="text-2xl font-bold">Side Projects</h2>
      </div>
      <div class="grid grid-cols-[repeat(auto-fill,minmax(300px,380px))] gap-5">
        {
          SITE.projects.map((project) => (
            <article class="card-accent-line bg-[#26262e] border border-[#2e2e3a] rounded-2xl p-6 relative overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:border-[var(--color-accent)] hover:shadow-[0_20px_40px_rgba(0,0,0,0.3)] cursor-pointer">
              <a
                href={project.pageUrl}
                class="absolute inset-0 z-0"
                aria-label={`View ${project.name} project page`}
              />
              <div class="w-11 h-11 bg-[#202027] rounded-xl flex items-center justify-center text-2xl mb-4">
                {project.icon}
              </div>
              <h3 class="text-lg font-semibold mb-2">{project.name}</h3>
              <p class="text-slate-400 text-sm leading-relaxed mb-4">{project.description}</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {project.tags.map((tag) => (
                  <span class="font-mono px-2.5 py-1 bg-[#202027] rounded text-[0.7rem] text-slate-500">
                    {tag}
                  </span>
                ))}
              </div>
              <div class="flex gap-4">
                <span class="relative z-10 inline-flex items-center gap-1.5 text-[var(--color-accent)] text-sm font-medium">
                  <svg
                    class="w-3.5 h-3.5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    <polyline points="15 3 21 3 21 9" />
                    <line x1="10" y1="14" x2="21" y2="3" />
                  </svg>
                  Project Page
                </span>
                <a
                  href={project.repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="relative z-10 inline-flex items-center gap-1.5 text-slate-500 text-sm font-medium hover:text-slate-300 transition-colors"
                >
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                  </svg>
                  Source
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Reading -->
    <section class="py-14 border-t border-[#2e2e3a]" id="reading">
      <div class="mb-8">
        <p class="font-mono text-xs text-[var(--color-accent)] uppercase tracking-widest mb-1">
          Reading
        </p>
        <div class="flex items-end justify-between">
          <h2 class="text-2xl font-bold">Bookmarks</h2>
          <a
            href={SITE.social.raindrop}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-slate-500 hover:text-[var(--color-accent)] transition-colors"
            >View all →</a
          >
        </div>
        <p class="text-slate-500 text-sm mt-1">
          Links I've saved — CS fundamentals, tools, games, and more.
        </p>
      </div>
      <div class="rounded-2xl overflow-hidden border border-[#2e2e3a] bg-[#202027]">
        <iframe
          class="block w-full h-[420px] lg:h-[620px]"
          style="border:0;"
          allowfullscreen
          frameborder="0"
          src="https://onurcakmakcs.raindrop.page/embed/me"
          loading="lazy"></iframe>
      </div>
    </section>

    <!-- Writing -->
    <section class="py-14 border-t border-[#2e2e3a]" id="writing">
      <div class="mb-8">
        <p class="font-mono text-xs text-[var(--color-accent)] uppercase tracking-widest mb-1">
          Writing
        </p>
        <div class="flex items-end justify-between">
          <h2 class="text-2xl font-bold">Articles</h2>
          <a
            href={SITE.social.medium}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-slate-500 hover:text-[var(--color-accent)] transition-colors"
            >All on Medium →</a
          >
        </div>
      </div>
      <div id="writing-list" class="flex flex-col gap-4">
        <div class="flex flex-col gap-3" id="writing-skeleton">
          {
            [1, 2].map(() => (
              <div class="h-24 rounded-xl bg-[#26262e] border border-[#2e2e3a] animate-pulse" />
            ))
          }
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-10 border-t border-[#2e2e3a]">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="text-slate-500 text-sm">{SITE.author.copyright}</p>
        <div class="flex gap-6">
          <a
            href={SITE.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-500 hover:text-slate-100 transition-colors text-sm">LinkedIn</a
          >
          <a
            href={SITE.social.github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-500 hover:text-slate-100 transition-colors text-sm">GitHub</a
          >
          <a
            href={SITE.social.medium}
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-500 hover:text-slate-100 transition-colors text-sm">Medium</a
          >
        </div>
      </div>
    </footer>
  </div>
</Layout>

<script define:vars={{ MEDIUM_RSS }}>
  async function loadMediumPosts() {
    const skeleton = document.getElementById('writing-skeleton');
    const list = document.getElementById('writing-list');

    try {
      const res = await fetch(MEDIUM_RSS);
      const data = await res.json();

      if (data.status !== 'ok' || !data.items?.length) throw new Error('No items');

      const posts = data.items.slice(0, 5);

      skeleton?.remove();

      posts.forEach((post) => {
        const thumbnail = post.thumbnail || post.enclosure?.link || null;
        const date = new Date(post.pubDate).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        const readTime = Math.max(
          1,
          Math.round((post.content?.replace(/<[^>]*>/g, '').split(/\s+/).length || 300) / 200)
        );

        list.insertAdjacentHTML(
          'beforeend',
          `
          <a href="${post.link}" target="_blank" rel="noopener noreferrer"
             class="group flex gap-4 p-4 bg-[#26262e] border border-[#2e2e3a] rounded-xl hover:border-[var(--color-accent)] hover:-translate-y-0.5 transition-all">
            ${
              thumbnail
                ? `
              <img src="${thumbnail}" alt="${post.title}"
                   class="w-20 h-20 rounded-lg object-cover shrink-0 bg-[#202027]"
                   loading="lazy" onerror="this.style.display='none'" />
            `
                : ''
            }
            <div class="min-w-0 flex-1">
              <h3 class="font-semibold text-slate-100 group-hover:text-[var(--color-accent)] transition-colors leading-snug mb-1 line-clamp-2">${post.title}</h3>
              <p class="text-sm text-slate-500 leading-relaxed line-clamp-2 mb-2">${post.description?.replace(/<[^>]*>/g, '').slice(0, 140)}...</p>
              <span class="text-xs text-slate-600 font-mono">${date} · ${readTime} min read</span>
            </div>
          </a>
        `
        );
      });
    } catch {
      skeleton?.remove();
      list.insertAdjacentHTML(
        'beforeend',
        `
        <p class="text-slate-500 text-sm">Couldn't load articles. <a href="https://medium.com/@onurcakmak" target="_blank" class="text-[var(--color-accent)] hover:underline">Read on Medium →</a></p>
      `
      );
    }
  }

  loadMediumPosts();
</script>
