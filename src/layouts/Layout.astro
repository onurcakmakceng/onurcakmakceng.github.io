---
import { SITE } from '../site.config';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  theme?: 'default' | 'baw' | 'rc';
}

const { title = SITE.title, description = SITE.description, theme = 'default' } = Astro.props;

const palettes = {
  default: {
    from: '#2563eb',
    via: '#0ea5e9',
    to: '#06b6d4',
    ambientA: 'rgba(37,99,235,0.12)',
    ambientB: 'rgba(6,182,212,0.08)',
    glowBtn: 'rgba(56,189,248,0.25)',
    accentDefault: '#38bdf8',
    accentLight: '#7dd3fc',
  },
  baw: {
    from: '#f97316',
    via: '#fb923c',
    to: '#fdba74',
    ambientA: 'rgba(249,115,22,0.12)',
    ambientB: 'rgba(251,146,60,0.08)',
    glowBtn: 'rgba(249,115,22,0.3)',
    accentDefault: '#fb923c',
    accentLight: '#fed7aa',
  },
  rc: {
    from: '#10b981',
    via: '#34d399',
    to: '#6ee7b7',
    ambientA: 'rgba(16,185,129,0.12)',
    ambientB: 'rgba(52,211,153,0.08)',
    glowBtn: 'rgba(16,185,129,0.3)',
    accentDefault: '#34d399',
    accentLight: '#a7f3d0',
  },
};

const palette = palettes[theme] ?? palettes.default;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={SITE.avatarUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style
      define:vars={{
        gradientFrom: palette.from,
        gradientVia: palette.via,
        gradientTo: palette.to,
        ambientA: palette.ambientA,
        ambientB: palette.ambientB,
        accentDefault: palette.accentDefault,
        accentLight: palette.accentLight,
      }}
    >
      :root {
        --color-surface-base: #18181c;
        --color-surface-raised: #202027;
        --color-surface-card: #26262e;
        --color-surface-border: #2e2e3a;
        --color-accent: var(--accentDefault);
        --color-accent-light: var(--accentLight);
      }

      body {
        font-family: 'Outfit', sans-serif;
      }

      .gradient-text {
        background: linear-gradient(
          135deg,
          var(--gradientFrom) 0%,
          var(--gradientVia) 50%,
          var(--gradientTo) 100%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .gradient-bg {
        background: linear-gradient(
          135deg,
          var(--gradientFrom) 0%,
          var(--gradientVia) 50%,
          var(--gradientTo) 100%
        );
      }

      .ambient-glow {
        background:
          radial-gradient(ellipse 80% 50% at 20% -20%, var(--ambientA) 0%, transparent 50%),
          radial-gradient(ellipse 60% 40% at 80% 100%, var(--ambientB) 0%, transparent 50%);
      }

      .card-accent-line::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(
          135deg,
          var(--gradientFrom) 0%,
          var(--gradientVia) 50%,
          var(--gradientTo) 100%
        );
        opacity: 0;
        transition: opacity 0.3s;
        border-radius: 20px 20px 0 0;
      }
      .card-accent-line:hover::before {
        opacity: 1;
      }

      .step-highlight {
        border-color: var(--accentDefault) !important;
        box-shadow: 0 0 30px color-mix(in srgb, var(--accentDefault) 30%, transparent);
      }

      .hero-image-glow {
        box-shadow:
          0 25px 80px rgba(0, 0, 0, 0.4),
          0 0 60px color-mix(in srgb, var(--accentDefault) 25%, transparent);
      }

      .noise {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      }
    </style>
  </head>
  <body class="bg-[#18181c] text-slate-100 min-h-screen overflow-x-hidden">
    <div class="noise fixed inset-0 pointer-events-none opacity-[0.03] z-[1000]"></div>
    <div class="ambient-glow fixed inset-0 pointer-events-none"></div>
    <slot />
  </body>
</html>
